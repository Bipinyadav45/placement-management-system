<?xml version="1.0" encoding="UTF-8"?>
<web-app version="4.0" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd">
    <servlet>
        <servlet-name>AddStudentServlet</servlet-name>
        <servlet-class>com.placement.AddStudentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>AddCompanyServlet</servlet-name>
        <servlet-class>com.placement.AddCompanyServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>TestServlet</servlet-name>
        <servlet-class>com.pms.TestServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>QuestionServlet</servlet-name>
        <servlet-class>com.question.QuestionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>SaveProfileServlet</servlet-name>
        <servlet-class>UploadResume.SaveProfileServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RecruiterDashboardServlet</servlet-name>
        <servlet-class>servlet.RecruiterDashboardServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentServlet</servlet-name>
        <servlet-class>StudentServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>StudentActionServlet</servlet-name>
        <servlet-class>action.StudentActionServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>ShortlistServlet</servlet-name>
        <servlet-class>controller.ShortlistServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>RejectServlet</servlet-name>
        <servlet-class>controller.RejectServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddStudentServlet</servlet-name>
        <url-pattern>/AddStudentServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AddCompanyServlet</servlet-name>
        <url-pattern>/AddCompanyServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>TestServlet</servlet-name>
        <url-pattern>/TestServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>QuestionServlet</servlet-name>
        <url-pattern>/QuestionServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>SaveProfileServlet</servlet-name>
        <url-pattern>/SaveProfileServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RecruiterDashboardServlet</servlet-name>
        <url-pattern>/RecruiterDashboardServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentServlet</servlet-name>
        <url-pattern>/students</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>StudentActionServlet</servlet-name>
        <url-pattern>/StudentActionServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>ShortlistServlet</servlet-name>
        <url-pattern>/ShortlistServlet</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>RejectServlet</servlet-name>
        <url-pattern>/RejectServlet</url-pattern>
    </servlet-mapping>
    <session-config>
        <session-timeout>
            30
        </session-timeout>
    </session-config>
</web-app>
